# 企业信息化管理系统 GREEN — 买断版配置文件模板
# 使用方式：复制为 .env，按需修改其中的值

# ========== 模式切换（必须）==========
# 买断版：standalone，租赁版：subscription
TENANT_MODE=standalone

# 买断版固定公司ID（从"系统管理 > 公司管理"页面查看）
# 所有用户、数据都限定在这个公司下
DEFAULT_COMPANY_ID=1

# ========== Django ==========
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,你的域名或IP

SECRET_KEY=修改为随机字符串，线上必须修改

# ========== 数据库（买断版用 PostgreSQL）==========
DB_ENGINE=django.db.backends.postgresql
DB_NAME=engineering
DB_USER=engineering
DB_PASSWORD=修改为强密码
DB_HOST=db
DB_PORT=5432

# ========== Redis ===========
REDIS_URL=redis://redis:6379/0

# ========== 邮件（SMTP，用于密码重置）==========
# 暂时不配置，密码重置功能将跳过邮件发送
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_FROM=no-reply@yourcompany.com
