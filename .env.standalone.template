# ============================================================
# 企业信息化管理系统 GREEN — 买断版配置模板
# 复制本文件为 .env，修改其中所有 *** 值
# ============================================================

# ========== 模式（必须）==========
TENANT_MODE=standalone
DEFAULT_COMPANY_ID=1

# ========== Django（必须）==========
DEBUG=False
ALLOWED_HOSTS=你的服务器IP,localhost,127.0.0.1
SECRET_KEY=在此填入至少50字符的随机密钥

# ========== 数据库（PostgreSQL）==========
# settings.py 读取 PG_* 环境变量
PG_DATABASE=engineering
PG_USER=engineering
PG_PASSWORD=***设置PostgreSQL密码***
PG_HOST=db
PG_PORT=5432

# ========== Redis（必须）==========
REDIS_PASSWORD=***设置Redis密码***

# ========== 应用端口（可选）==========
APP_PORT=8001
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ========== CORS（可选）==========
CORS_ALLOWED_ORIGINS=http://你的服务器IP:8001,https://你的域名

# ========== 邮件（可选，生产环境替换为真实SMTP）==========
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.exmail.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@company.com
EMAIL_HOST_PASSWORD=***邮箱密码或授权码***
DEFAULT_FROM_EMAIL=GREEN ERP <your-email@company.com>

# ========== 超级管理员（可选，留空则不自动创建）==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=***设置管理员密码***
ADMIN_EMAIL=admin@example.com
