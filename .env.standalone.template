# ============================================================
# 企业信息化管理系统 GREEN — 买断版配置模板
# 买断版（Perpetual / Standalone）部署配置
#
# 复制本文件为 .env，然后修改里面的值
# ============================================================

# ─── 必填配置 ───

# 租户模式：买断版写 standalone（固定值，禁止修改）
TENANT_MODE=standalone

# 买断版专用：指定系统使用的默认公司ID
# 公司ID在 Django Admin → Finance → Companies 里查看
# 示例：DEFAULT_COMPANY_ID=3
DEFAULT_COMPANY_ID=3

# Django 密钥（必填，生产环境必须修改）
# 生成方式：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=这里填入你的SECRET_KEY

# 允许访问的域名（用逗号分隔）
# 示例：ALLOWED_HOSTS=erp.example.com,www.erp.example.com
ALLOWED_HOSTS=*

# PostgreSQL 数据库配置
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=engineering_new
PG_USER=engineer
PG_PASSWORD=这里填入数据库密码

# ─── 可选配置 ───

# 调试模式（买断版建议关闭）
DEBUG=False

# 邮件配置（买断版如需发送邮件通知，填入SMTP配置）
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.exmail.qq.com
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=admin@example.com
# EMAIL_HOST_PASSWORD=邮箱密码
# DEFAULT_FROM_EMAIL=企业信息化管理系统 <admin@example.com>
