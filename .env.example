# ============================================================
# 工程管理系统 - 生产环境配置模板
# 复制本文件为 .env，然后填入真实值
# ============================================================

# 必填：随机密钥（至少50字符）
SECRET_KEY=your-super-secret-key-at-least-50-chars-here

# 必填：允许的域名/IP（逗号分隔）
ALLOWED_HOSTS=43.156.139.37,localhost,127.0.0.1

# 必填：切换到 False 关闭调试
DEBUG=False

# 可选：数据库（默认 SQLite）
# DATABASE_URL=sqlite:///db.sqlite3

# 可选：静态文件根路径
# STATIC_ROOT=/var/www/engineering/staticfiles

# 可选：媒体文件根路径
# MEDIA_ROOT=/var/www/engineering/media

# 可选：CORS 允许的来源（逗号分隔，为空则全部禁止）
CORS_ALLOWED_ORIGINS=http://43.156.139.37:8001,https://your-domain.com
