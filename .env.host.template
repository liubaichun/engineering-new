# ============================================================
# 企业信息化管理系统 GREEN — Host模式环境变量模板
# 复制本文件为 /etc/engineering-env（systemd读取）
# 同时复制一份到项目根目录 .env（Django读取，两者互补）
# ============================================================
#
# 【必填项】以下变量必须设置，否则Django无法启动
#

# ── Django核心（必须）────────────────────────────
DEBUG=False
SECRET_KEY=***请填入至少50字符的随机密钥***
ALLOWED_HOSTS=你的服务器IP,localhost,127.0.0.1

# ── PostgreSQL数据库（必须）────────────────────────
PG_USER=engineer
PG_PASSWORD=***数据库密码***
PG_DATABASE=engineering_new
PG_HOST=localhost

# ── Redis（必须，用于session等）────────────────────
REDIS_PASSWORD=***Redis密码***

# ── 飞书渠道（可选，无飞书功能可留空）────────────
# CHANNEL_CREDENTIAL_KEY=***飞书渠道凭证***
# CHANNEL_STATE_KEY=***飞书状态密钥***

# ── 邮件（可选，不配置则使用console后端）────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.exmail.qq.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=your-email@company.com
# EMAIL_HOST_PASSWORD=***
# DEFAULT_FROM_EMAIL=GREEN ERP <your-email@company.com>

# ── CORS（可选）──────────────────────────────────
CORS_ALLOWED_ORIGINS=http://你的服务器IP:8001

# ── 多租户模式（买断版用standalone，托管版用subscription）─
TENANT_MODE=standalone
DEFAULT_COMPANY_ID=1
